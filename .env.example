# Azure OpenAI (required)
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=7cX...
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_DEPLOYMENT_MINI=gpt-4o-mini

# Vapi Voice (optional — set VOICE_MODE=live to use)
VAPI_API_KEY=...
VAPI_PHONE_NUMBER_ID=...
VAPI_WEBHOOK_URL=https://<ngrok-or-public-url>/webhook/vapi

# Temporal
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=collections

# API
API_HOST=0.0.0.0
API_PORT=8000

# Voice mode: "simulated" for testing (chat mode), "live" for actual Vapi calls
VOICE_MODE=live


LANGFUSE_SECRET_KEY=sk-...
LANGFUSE_PUBLIC_KEY=pk-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Email (Gmail SMTP — summary sent to borrower on workflow completion)
EMAIL_FROM=you@gmail.com
GOOGLE_APP_PASSWORD=xxxx xxxx xxxx xxxx
